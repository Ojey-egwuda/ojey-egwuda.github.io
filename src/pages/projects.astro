---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { aiProjects, mlProjects, allProjects } from '../data/projects';
---

<Layout
  title="Projects | Ojey Egwuda"
  description="12+ AI and ML projects including multi-agent RAG systems, LangGraph pipelines, and production ML apps. All with live demos and source code."
>
  <Header />

  <main class="flex-1 pt-16">
    <!-- Header -->
    <section class="container-custom py-20">
      <h1 class="text-4xl md:text-5xl font-display font-bold mb-4">Projects</h1>
      <p class="text-dark-400 text-lg max-w-2xl mb-8">
        {allProjects.length} projects across AI/agentic systems and machine learning. Each includes live demos and source code.
      </p>

      <!-- Filter tabs -->
      <div class="flex flex-wrap gap-2" id="filter-tabs">
        <button
          class="filter-btn active px-5 py-2 rounded-xl text-sm font-medium border transition-all duration-200"
          data-filter="all"
        >
          All ({allProjects.length})
        </button>
        <button
          class="filter-btn px-5 py-2 rounded-xl text-sm font-medium border transition-all duration-200"
          data-filter="ai"
        >
          AI & Agentic ({aiProjects.length})
        </button>
        <button
          class="filter-btn px-5 py-2 rounded-xl text-sm font-medium border transition-all duration-200"
          data-filter="ml"
        >
          ML & Data Science ({mlProjects.length})
        </button>
      </div>
    </section>

    <!-- AI Projects -->
    <section class="container-custom pb-20" id="section-ai" data-category="ai">
      <div class="flex items-center gap-3 mb-8">
        <div class="w-10 h-10 rounded-xl bg-accent-500/10 flex items-center justify-center">
          <svg class="w-5 h-5 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
        </div>
        <h2 class="text-2xl font-display font-semibold">AI & Agentic Systems</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {aiProjects.map(project => (
          <ProjectCard {...project} />
        ))}
      </div>
    </section>

    <!-- ML Projects -->
    <section class="container-custom pb-20 section-divider pt-20" id="section-ml" data-category="ml">
      <div class="flex items-center gap-3 mb-8">
        <div class="w-10 h-10 rounded-xl bg-accent-500/10 flex items-center justify-center">
          <svg class="w-5 h-5 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
          </svg>
        </div>
        <h2 class="text-2xl font-display font-semibold">Machine Learning & Data Science</h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {mlProjects.map(project => (
          <ProjectCard {...project} />
        ))}
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .filter-btn {
    background: rgba(255, 255, 255, 0.7);
    border-color: rgba(200, 197, 222, 0.8);
    color: rgb(74, 72, 112);
  }
  .filter-btn:hover {
    border-color: rgba(0, 194, 216, 0.5);
    color: rgb(0, 160, 180);
    background: rgba(255,255,255,0.9);
  }
  .filter-btn.active {
    background: rgba(0, 194, 216, 0.08);
    border-color: rgba(0, 194, 216, 0.45);
    color: rgb(0, 160, 180);
  }
</style>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const sectionAi = document.getElementById('section-ai');
  const sectionMl = document.getElementById('section-ml');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      buttons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      const filter = btn.dataset.filter;

      if (filter === 'all') {
        sectionAi?.classList.remove('hidden');
        sectionMl?.classList.remove('hidden');
        sectionMl?.classList.remove('border-t', 'border-dark-800/50', 'pt-20');
        sectionMl?.classList.add('border-t', 'border-dark-800/50', 'pt-20');
      } else if (filter === 'ai') {
        sectionAi?.classList.remove('hidden');
        sectionMl?.classList.add('hidden');
      } else if (filter === 'ml') {
        sectionAi?.classList.add('hidden');
        sectionMl?.classList.remove('hidden');
        sectionMl?.classList.remove('border-t', 'border-dark-800/50', 'pt-20');
      }
    });
  });
</script>
