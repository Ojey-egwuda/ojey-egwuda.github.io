---
const currentYear = new Date().getFullYear();

const socialLinks = [
  { href: 'https://github.com/Ojey-egwuda', label: 'GitHub', icon: 'github' },
  { href: 'https://www.linkedin.com/in/egwudaojonugwa/', label: 'LinkedIn', icon: 'linkedin' },
  { href: 'mailto:ojonugwaegwuda@gmail.com', label: 'Email', icon: 'email' },
];
---

<footer class="border-t border-dark-800/50 mt-auto">
  <div class="container-custom py-12">
    <div class="grid md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <a href="/" class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-accent-400 to-accent-600 flex items-center justify-center font-display font-bold text-dark-950 text-lg">
            OE
          </div>
          <span class="font-display font-semibold text-dark-100">Ojey Egwuda</span>
        </a>
        <p class="text-dark-400 text-sm leading-relaxed">
          AI Developer & Data Scientist building intelligent systems that solve real-world problems.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="font-display font-semibold text-dark-200 mb-4">Quick Links</h4>
        <ul class="space-y-2">
          <li><a href="/projects" class="text-dark-400 hover:text-accent-400 text-sm transition-colors">Projects</a></li>
          <li><a href="/about" class="text-dark-400 hover:text-accent-400 text-sm transition-colors">About Me</a></li>
          <li><a href="/blog" class="text-dark-400 hover:text-accent-400 text-sm transition-colors">Blog</a></li>
          <li><a href="mailto:ojonugwaegwuda@gmail.com" class="text-dark-400 hover:text-accent-400 text-sm transition-colors">Contact</a></li>
        </ul>
      </div>

      <!-- Connect -->
      <div>
        <h4 class="font-display font-semibold text-dark-200 mb-4">Connect</h4>
        <div class="flex gap-4">
          <a 
            href="https://github.com/Ojey-egwuda" 
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 rounded-lg bg-dark-800 flex items-center justify-center text-dark-400 hover:text-accent-400 hover:bg-dark-700 transition-all"
            aria-label="GitHub"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
            </svg>
          </a>
          <a 
            href="https://www.linkedin.com/in/egwudaojonugwa/" 
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 rounded-lg bg-dark-800 flex items-center justify-center text-dark-400 hover:text-accent-400 hover:bg-dark-700 transition-all"
            aria-label="LinkedIn"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <!-- Email with click-to-copy -->
          <div class="relative group">
            <button 
              id="email-copy-btn"
              class="w-10 h-10 rounded-lg bg-dark-800 flex items-center justify-center text-dark-400 hover:text-accent-400 hover:bg-dark-700 transition-all"
              aria-label="Copy email address"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </button>
            <!-- Tooltip -->
            <div id="email-tooltip" class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 px-3 py-2 bg-dark-800 border border-dark-700 rounded-lg text-sm whitespace-nowrap opacity-0 pointer-events-none transition-opacity group-hover:opacity-100">
              <span id="email-text">ojonugwaegwuda@gmail.com</span>
              <span id="copied-text" class="hidden text-accent-400">Copied!</span>
            </div>
          </div>
        </div>
        <!-- Email display -->
        <p class="text-dark-400 text-sm mt-4">
          <a href="mailto:ojonugwaegwuda@gmail.com" class="hover:text-accent-400 transition-colors">ojonugwaegwuda@gmail.com</a>
        </p>
        <p class="text-dark-500 text-sm mt-1">
          Oxford, United Kingdom
        </p>
      </div>
    </div>

    <!-- Bottom -->
    <div class="border-t border-dark-800 mt-8 pt-8 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-dark-500 text-sm">
        © {currentYear} Ojonugwa Egwuda. All rights reserved.
      </p>
      <p class="text-dark-600 text-xs">
        Built with Astro & Tailwind CSS
      </p>
    </div>
  </div>
</footer>

<script>
  const emailBtn = document.getElementById('email-copy-btn');
  const emailText = document.getElementById('email-text');
  const copiedText = document.getElementById('copied-text');
  
  emailBtn?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText('ojonugwaegwuda@gmail.com');
      emailText?.classList.add('hidden');
      copiedText?.classList.remove('hidden');
      
      setTimeout(() => {
        emailText?.classList.remove('hidden');
        copiedText?.classList.add('hidden');
      }, 2000);
    } catch (err) {
      // Fallback: open mailto
      window.location.href = 'mailto:ojonugwaegwuda@gmail.com';
    }
  });
</script>
