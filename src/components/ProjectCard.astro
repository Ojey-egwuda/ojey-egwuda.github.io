---
interface Props {
  slug: string;
  title: string;
  description: string;
  tags: string[];
  liveUrl?: string;
  githubUrl?: string;
  featured?: boolean;
  image?: string;
  category?: 'ai' | 'ml';
}

const { slug, title, description, tags, liveUrl, githubUrl, featured = false, image } = Astro.props;
const caseStudyUrl = `/projects/${slug}`;
---

<article class={`card card-glow p-6 flex flex-col ${featured ? 'md:col-span-2' : ''}`}>
  <!-- Project image -->
  {image && (
    <div class="mb-5 rounded-xl overflow-hidden bg-dark-800 aspect-video">
      <img
        src={image}
        alt={`${title} preview`}
        class="w-full h-full object-cover opacity-75 hover:opacity-95 transition-opacity duration-300"
        loading="lazy"
      />
    </div>
  )}

  <div class="relative z-10 flex flex-col flex-1">
    <!-- Featured badge -->
    {featured && (
      <span class="tag tag-accent text-xs mb-3 self-start">Featured Project</span>
    )}

    <!-- Title -->
    <h3 class="text-xl font-display font-semibold text-dark-100 mb-2 hover:text-accent-400 transition-colors">
      <a href={caseStudyUrl}>{title}</a>
    </h3>

    <!-- Description -->
    <p class="text-dark-400 text-sm leading-relaxed mb-4 flex-1">
      {description}
    </p>

    <!-- Tags -->
    <div class="flex flex-wrap gap-2 mb-5">
      {tags.map(tag => (
        <span class="tag text-xs">{tag}</span>
      ))}
    </div>

    <!-- Links -->
    <div class="flex flex-wrap gap-2 relative z-20">
      {liveUrl && liveUrl !== '#' && (
        <a
          href={liveUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary text-sm py-2"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
          </svg>
          Live App
        </a>
      )}
      {githubUrl && (
        <a
          href={githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-secondary text-sm py-2"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
          </svg>
          GitHub
        </a>
      )}
      <a
        href={caseStudyUrl}
        class="btn-secondary text-sm py-2"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
        </svg>
        Case Study
      </a>
    </div>
  </div>
</article>
